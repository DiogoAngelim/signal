{
  "name": "weather-signal-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Weather Signal Server - real-time hazard intelligence API",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "test": "vitest run",
    "lint": "biome check src tests",
    "smoke": "tsx src/cli.ts smoke",
    "poll:forecast": "tsx src/cli.ts poll:forecast",
    "poll:alerts": "tsx src/cli.ts poll:alerts",
    "replay": "tsx src/cli.ts replay"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/websocket": "^10.0.1",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "pino": "^9.3.2",
    "ws": "^8.17.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^20.17.16",
    "@types/ws": "^8.5.12",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  }

{
  "name": "@signal/examples",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./payment-capture": "./dist/payment-capture/index.js",
    "./escrow-release": "./dist/escrow-release/index.js",
    "./user-onboarding": "./dist/user-onboarding/index.js",
    "./kafka-postgresql": "./dist/kafka-postgresql/index.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "payment-capture": "node dist/payment-capture/index.js",
    "escrow-release": "node dist/escrow-release/index.js",
    "user-onboarding": "node dist/user-onboarding/index.js",
    "kafka-postgresql": "node dist/kafka-postgresql/index.js"
  },
  "dependencies": {
    "@signal/protocol": "workspace:*",
    "@signal/runtime": "workspace:*",
    "@signal/sdk-node": "workspace:*",
    "@signal/idempotency-postgres": "workspace:*",
    "kafkajs": "^2.2.4",
    "pg": "^8.13.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^20.17.16",
    "@types/pg": "^8.11.10",
    "typescript": "^5.7.3"
  }
}

{
  "name": "@signal/examples",
  "version": "0.1.0",
  "private": false,
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./minimal-runtime": "./dist/minimal-runtime/index.js",
    "./post-publication": "./dist/post-publication/index.js",
    "./http-post-publication": "./dist/http-post-publication/index.js",
    "./capabilities-inspection": "./dist/capabilities-inspection/index.js",
    "./storage-backed-idempotency": "./dist/storage-backed-idempotency/index.js",
    "./custom-transport-skeleton": "./dist/custom-transport-skeleton/index.js",
    "./payment-capture": "./dist/payment-capture/index.js",
    "./escrow-release": "./dist/escrow-release/index.js",
    "./user-onboarding": "./dist/user-onboarding/index.js",
    "./kafka-postgresql": "./dist/kafka-postgresql/index.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "minimal-runtime": "node --env-file-if-exists=.env.local dist/minimal-runtime/index.js",
    "post-publication": "node --env-file-if-exists=.env.local dist/post-publication/index.js",
    "http-post-publication": "node --env-file-if-exists=.env.local dist/http-post-publication/index.js",
    "capabilities-inspection": "node --env-file-if-exists=.env.local dist/capabilities-inspection/index.js",
    "storage-backed-idempotency": "node --env-file-if-exists=.env.local dist/storage-backed-idempotency/index.js",
    "custom-transport-skeleton": "node --env-file-if-exists=.env.local dist/custom-transport-skeleton/index.js",
    "payment-capture": "node --env-file-if-exists=.env.local dist/payment-capture/index.js",
    "escrow-release": "node --env-file-if-exists=.env.local dist/escrow-release/index.js",
    "user-onboarding": "node --env-file-if-exists=.env.local dist/user-onboarding/index.js",
    "kafka-postgresql": "node --env-file-if-exists=.env.local dist/kafka-postgresql/index.js"
  },
  "dependencies": {
    "@signal/binding-http": "workspace:*",
    "@signal/protocol": "workspace:*",
    "@signal/runtime": "workspace:*",
    "@signal/sdk-node": "workspace:*",
    "@signal/idempotency-postgres": "workspace:*",
    "kafkajs": "^2.2.4",
    "pg": "^8.13.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^20.17.16",
    "@types/pg": "^8.11.10",
    "typescript": "^5.7.3"
  }
}

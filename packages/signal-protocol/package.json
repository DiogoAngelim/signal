{
  "name": "@digelim/signal-protocol",
  "version": "0.1.0",
  "description": "Full-stack Signal demo library with API routes and client assets.",
  "license": "MIT",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./api": {
      "require": "./dist/api.js",
      "types": "./dist/api.d.ts"
    },
    "./server": {
      "require": "./dist/server.js",
      "types": "./dist/server.d.ts"
    },
    "./client": {
      "require": "./dist/client.js",
      "types": "./dist/client.d.ts"
    }
  },
  "files": [
    "dist",
    "client",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:client": "node ./scripts/build-client.mjs",
    "prepack": "pnpm run build:client && pnpm run build",
    "clean": "rm -rf dist client"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.17.16",
    "typescript": "^5.7.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://signal.dev/schemas/capabilities.schema.json",
  "title": "Signal Capabilities",
  "type": "object",
  "required": [
    "protocol",
    "version",
    "queries",
    "mutations",
    "publishedEvents",
    "subscribedEvents"
  ],
  "properties": {
    "protocol": {
      "const": "signal.v1"
    },
    "version": {
      "const": "v1"
    },
    "queries": {
      "type": "array"
    },
    "mutations": {
      "type": "array"
    },
    "publishedEvents": {
      "type": "array"
    },
    "subscribedEvents": {
      "type": "array"
    },
    "features": {
      "type": "object",
      "additionalProperties": true
    },
    "bindings": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}

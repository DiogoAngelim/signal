{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://signal.dev/schemas/user-onboarded.event.schema.json",
  "title": "User Onboarded Event",
  "type": "object",
  "required": ["userId", "email", "plan", "onboardedAt"],
  "properties": {
    "userId": { "type": "string" },
    "email": { "type": "string", "format": "email" },
    "plan": { "enum": ["free", "pro"] },
    "onboardedAt": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}

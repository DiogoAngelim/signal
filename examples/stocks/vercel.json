{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm --dir src install",
  "buildCommand": "pnpm --dir src run build && node ./copy-public.mjs",
  "outputDirectory": "public",
  "functions": {
    "api/index.cjs": {
      "includeFiles": "src/artifacts/**",
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api?path=$1"
    },
    {
      "source": "/dashboard",
      "destination": "/index.html"
    },
    {
      "source": "/dashboard/(.*)",
      "destination": "/index.html"
    }
  ]
}
